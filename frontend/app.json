{
  "expo": {
    "name": "PrescoPad",
    "slug": "PrescoPad",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0077B6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prescopad.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "PrescoPad needs microphone access to record consultations for transcription."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0077B6"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.prescopad.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "cf59fdd9-7225-45f4-9bdc-7f9b4493b51b"
      }
    }
  }
}
